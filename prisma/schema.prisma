generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SplitType {
  EQUAL  @map("equal")
  CUSTOM @map("custom")

  @@map("split_type")
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  name         String
  email        String        @unique
  avatarUrl    String?       @map("avatar_url")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  ownedGroups  Group[]       @relation("GroupOwner")
  groupMembers GroupMember[]

  @@map("users")
}

model Group {
  id                 String              @id @default(uuid()) @db.Uuid
  ownerUserId        String              @map("owner_user_id") @db.Uuid
  name               String
  description        String?
  currency           String
  archivedAt         DateTime?           @map("archived_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  ownerUser          User                @relation("GroupOwner", fields: [ownerUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  groupMembers       GroupMember[]
  expenses           Expense[]
  settlementPayments SettlementPayment[]

  @@index([ownerUserId])
  @@map("groups")
}

model GroupMember {
  id               String              @id @default(uuid()) @db.Uuid
  groupId          String              @map("group_id") @db.Uuid
  userId           String?             @map("user_id") @db.Uuid
  displayName      String              @map("display_name")
  email            String?
  removedAt        DateTime?           @map("removed_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  group            Group               @relation(fields: [groupId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user             User?               @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  paidExpenses     Expense[]           @relation("ExpensePaidByMember")
  expenseSplits    ExpenseSplit[]
  outgoingPayments SettlementPayment[] @relation("SettlementFromMember")
  incomingPayments SettlementPayment[] @relation("SettlementToMember")

  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

model Expense {
  id             String         @id @default(uuid()) @db.Uuid
  groupId        String         @map("group_id") @db.Uuid
  title          String
  amount         Decimal        @db.Decimal(12, 2)
  currency       String
  paidByMemberId String         @map("paid_by_member_id") @db.Uuid
  splitType      SplitType      @map("split_type")
  category       String?
  notes          String?
  expenseDate    DateTime       @map("expense_date")
  deletedAt      DateTime?      @map("deleted_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  group          Group          @relation(fields: [groupId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  paidByMember   GroupMember    @relation("ExpensePaidByMember", fields: [paidByMemberId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  expenseSplits  ExpenseSplit[]

  @@index([groupId])
  @@index([paidByMemberId])
  @@map("expenses")
}

model ExpenseSplit {
  id         String      @id @default(uuid()) @db.Uuid
  expenseId  String      @map("expense_id") @db.Uuid
  memberId   String      @map("member_id") @db.Uuid
  owedAmount Decimal     @map("owed_amount") @db.Decimal(12, 2)
  paidAmount Decimal     @map("paid_amount") @db.Decimal(12, 2)
  netAmount  Decimal     @map("net_amount") @db.Decimal(12, 2)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  expense    Expense     @relation(fields: [expenseId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  member     GroupMember @relation(fields: [memberId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([expenseId])
  @@index([memberId])
  @@map("expense_splits")
}

model SettlementPayment {
  id           String      @id @default(uuid()) @db.Uuid
  groupId      String      @map("group_id") @db.Uuid
  fromMemberId String      @map("from_member_id") @db.Uuid
  toMemberId   String      @map("to_member_id") @db.Uuid
  amount       Decimal     @db.Decimal(12, 2)
  currency     String
  paidAt       DateTime    @map("paid_at")
  notes        String?
  deletedAt    DateTime?   @map("deleted_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  group        Group       @relation(fields: [groupId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  fromMember   GroupMember @relation("SettlementFromMember", fields: [fromMemberId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  toMember     GroupMember @relation("SettlementToMember", fields: [toMemberId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([groupId])
  @@index([fromMemberId])
  @@index([toMemberId])
  @@map("settlement_payments")
}
