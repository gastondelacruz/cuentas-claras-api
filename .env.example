NODE_ENV=development
PORT=3000
DATABASE_URL="postgresql://cuentas_claras:cuentas_claras@localhost:5432/cuentas_claras?schema=public"
JWT_ACCESS_SECRET="replace-with-at-least-32-characters"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="replace-with-at-least-32-characters"
JWT_REFRESH_TTL="30d"
GOOGLE_CLIENT_ID=""
# HMAC-SHA256 secret used to compute a fast lookup digest for refresh tokens.
# Must be at least 32 characters. Keep independent from JWT secrets so each
# can be rotated separately.
REFRESH_TOKEN_DIGEST_SECRET="replace-with-at-least-32-characters"
